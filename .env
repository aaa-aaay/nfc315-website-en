# 网站主标题
VITE_GLOBAL_TITLE= 'DMS'

# footer
VITE_FOOTER_TITLE= '©2025 nfc315.com'

# 是否是微服务架构（重要）
VITE_IS_MICRO= false

# 前端访问前缀
VITE_PUBLIC_PATH = /

# 后端请求前缀
VITE_API_URL = /api

# ADMIN 服务地址
VITE_ADMIN_PROXY_PATH = https://www.nfc315.com/api/

# 前端加密密钥
VITE_PWD_ENC_KEY='wmsnfc315nfcwms@'

# OAUTH2 密码模式客户端信息
VITE_OAUTH2_PASSWORD_CLIENT='dms:dms'

# OAUTH2 短信客户端信息
VITE_OAUTH2_MOBILE_CLIENT='app:app'

# OAUTH2 社交登录客户端信息
VITE_OAUTH2_SOCIAL_CLIENT='social:social'

# 是否开启前端滑块验证码
VITE_VERIFY_ENABLE = true

# 是否开启前端图形验证码
VITE_VERIFY_IMAGE_ENABLE = false

# 是否开启websocket 消息接受,
VITE_WEBSOCKET_ENABLE = false

# 是否开启注册
VITE_REGISTER_ENABLE  = true

# 是否开启租户自动选择 （根据租户域名）
VITE_AUTO_TENANT = false

# 是否开启多语言切换
VITE_I18N_ENABLE = true

# 是否开启暗黑模式切换
VITE_DARK_MODE_ENABLE = true

# 是否启用禁用浏览器调试功能（反爬）
VITE_ENABLE_ANTI_DEBUG=false

# 绕过反爬参数值 url?ddtk=参数值
VITE_ANTI_DEBUG_KEY=pig
